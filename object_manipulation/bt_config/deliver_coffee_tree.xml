<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4" main_tree_to_execute="DeliverCoffeeRoot">
  <BehaviorTree ID="DeliverCoffeeRoot">
    <ReactiveSequence name="DeliverCoffee">
      <GoalNotCanceled/>
      <Sequence name="MainSequence">
        <Sequence name="CoffeeDelivery">
          <ValidateDetection name="Validate Detection"/>
          <PrePick name="Pre-pick"/>
          <Pick/>
          <Fallback name="PlaceOrRecover">
            <Sequence name="TrytoPlace">
              <RetryUntilSuccessful num_attempts="2">
                <PrePlace name="Pre-place"/>
              </RetryUntilSuccessful>
              <Sequence name="PlaceCore">
                <RetryUntilSuccessful num_attempts="2">
                  <InsertCup/>
                </RetryUntilSuccessful>
                <ReleaseCup/>
                <PostPlaceRetreat/>
              </Sequence>
            </Sequence>
            <Sequence name="RecoverAndFail">
              <PutBack name="Put Back"/>
              <Return/>
              <ForceFail/>
            </Sequence>
          </Fallback>
        </Sequence>
        <Return/>
      </Sequence>
    </ReactiveSequence>
  </BehaviorTree>

  <TreeNodesModel>
    <Condition ID="GoalNotCanceled"/>
    <Action ID="ValidateDetection"/>
    <Action ID="PrePick"/>
    <Action ID="Pick"/>
    <Action ID="PrePlace"/>
    <Action ID="Place"/>
    <Action ID="InsertCup"/>
    <Action ID="ReleaseCup"/>
    <Action ID="PostPlaceRetreat"/>
    <Action ID="PutBack"/>
    <Action ID="Return"/>
    <Action ID="ForceFail"/>
  </TreeNodesModel>
</root>
